# Copy to .env locally. Never commit real secrets.
# Server-side PostgreSQL connection string for Supabase.
# Never expose this value to the browser or commit it to Git.
DATABASE_URL=
JINA_BASE_URL=https://api.jina.ai/v1
JINA_API_KEY=
OPENAI_API_KEY=
EMBEDDING_PROVIDER=jina
EMBEDDING_MODEL=jina-embeddings-v5-text-small
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MAX_RETRIES=3
EMBEDDING_RETRY_BASE_SECONDS=1
GEMINI_API_KEY=
OPENROUTER_API_KEY=
# OpenAI is the default LLM provider. Override both values per environment.
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini
APP_ENV=development
APP_BASE_URL=
MOCK_HIS_BASE_URL=

# Local multilingual BGE reranker configuration
RERANKER_PROVIDER=bge
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_BASE_URL=https://api.jina.ai/v1/rerank
RERANKER_TIMEOUT_SECONDS=5.0
RERANKER_TOP_N=5
RERANKER_ENABLED=true
RERANKER_BATCH_SIZE=8
RERANKER_LOCAL_ONLY=true
# Leave empty for automatic CPU/MPS selection.
RERANKER_DEVICE=

# Safety evaluator configuration
SAFETY_PROVIDER=openai
SAFETY_MODEL=gpt-4o-mini
SAFETY_TIMEOUT_SECONDS=10.0

# Execution budgets
AGENT_MAX_TOOL_CALLS=5
RRF_K=60
