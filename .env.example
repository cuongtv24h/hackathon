# Copy to .env locally. Never commit real secrets.
# Server-side PostgreSQL connection string for Supabase.
# Never expose this value to the browser or commit it to Git.
DATABASE_URL=
# LLM provider key; retained for Gemini generation, not embeddings.
GEMINI_API_KEY=
# Embedding provider key for Jina jina-embeddings-v5-text-small.
JINA_API_KEY=
OPENROUTER_API_KEY=
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=jina-embeddings-v5-text-small
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BASE_URL=https://api.jina.ai/v1
APP_ENV=development
APP_BASE_URL=
MOCK_HIS_BASE_URL=
