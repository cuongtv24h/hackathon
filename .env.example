# Copy to .env locally. Never commit real secrets.
# Server-side PostgreSQL connection string for Supabase.
# Never expose this value to the browser or commit it to Git.
DATABASE_URL=
# LLM provider chain. Change only this order to change primary/fallback.
# Supported values: gemini, openrouter, groq. Every named provider needs a key.
LLM_PROVIDER_ORDER=groq,gemini,openrouter

# Gemini OpenAI-compatible provider.
LLM_GEMINI_API_KEY=
LLM_GEMINI_NAME=gemini
LLM_GEMINI_MODEL=gemini-2.5-flash
LLM_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_GEMINI_TIMEOUT_SECONDS=30
LLM_GEMINI_MAX_RETRIES=1

# OpenRouter provider.
LLM_OPENROUTER_API_KEY=
LLM_OPENROUTER_NAME=openrouter
LLM_OPENROUTER_MODEL=google/gemini-2.5-flash
LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_OPENROUTER_TIMEOUT_SECONDS=30
LLM_OPENROUTER_MAX_RETRIES=1

# Groq provider (OpenAI-compatible API).
LLM_GROQ_API_KEY=
LLM_GROQ_NAME=groq
LLM_GROQ_MODEL=llama-3.3-70b-versatile
LLM_GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_GROQ_TIMEOUT_SECONDS=30
LLM_GROQ_MAX_RETRIES=1

# Legacy aliases are accepted but should not be used for new configuration.
GEMINI_API_KEY=
OPENROUTER_API_KEY=
LLM_PRIMARY_API_KEY=
LLM_FALLBACK_API_KEY=
# Embedding provider key for Jina jina-embeddings-v5-text-small.
JINA_API_KEY=
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=jina-embeddings-v5-text-small
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BASE_URL=https://api.jina.ai/v1
# Maximum end-to-end time for query embedding plus Supabase vector retrieval.
# Use a value that fits your deployment latency budget.
RAG_SEARCH_TIMEOUT_MS=8000
APP_ENV=development
APP_BASE_URL=
# Comma-separated browser origins. Do not use * in Pilot/production.
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
# Frontend development only. Vite proxies /v1 to this private API target.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
# Leave blank for same-origin deployment; otherwise use the public API origin.
VITE_API_BASE_URL=
MOCK_HIS_BASE_URL=http://127.0.0.1:8001
